{
  "topological_sort": {
    "description": "Bottom-to-top ordering: Level 0 = raw source columns, higher levels = derived/aggregated KPIs. Each node only depends on nodes in lower levels.",
    "levels": [
      {
        "level": 0,
        "label": "Raw Sources (Table Columns)",
        "nodes": [
          {
            "id": "Actual_Delivery_Date",
            "label": "Actual Delivery Date",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "On_Time",
              "Avg_Delay_Duration",
              "Delay_Risk",
              "OTIF"
            ],
            "source_table": "Delivery_Dim",
            "source_column": "Delivery_Date"
          },
          {
            "id": "Avg_Delay_Duration_ms",
            "label": "Avg delay duration (ms)",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "Avg_Days_Delay_Duration",
              "Avg_Delay_Days_Dashboard"
            ],
            "source_table": "_ARIS.Case",
            "source_column": "Avg delay duration"
          },
          {
            "id": "Cases_Table",
            "label": "ARIS Cases Table (pre-aggregated)",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "Open_Orders",
              "Num_Warehouse",
              "Orders_At_Risk_Dashboard",
              "Delay_Order_Value",
              "Packing_Accuracy",
              "Num_Shipment_Affected",
              "Value_at_Risk",
              "Savings_Lost",
              "Utilization_Efficiency",
              "Num_Materials",
              "Num_Total_Operators"
            ],
            "source_table": "cases",
            "source_column": "value"
          },
          {
            "id": "City",
            "label": "City",
            "type": "source",
            "depends_on": [],
            "feeds_into": [],
            "source_table": "Delivery_Dim",
            "source_column": "Source City"
          },
          {
            "id": "Delay_Reason",
            "label": "Delay Reason for Delivery",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "Orders_at_Risk"
            ],
            "source_table": "Supply_Chain_KPI_Tuned",
            "source_column": "Delay Reason for Delivery"
          },
          {
            "id": "Delivered_Quantity",
            "label": "Delivered Quantity",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "InFull",
              "Delay_Risk",
              "OTIF"
            ],
            "source_table": "Sales Order DIM",
            "source_column": "Delivered Quantity"
          },
          {
            "id": "Delivery_Number",
            "label": "Delivery Number",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "Delivery_On_Time_Pct"
            ],
            "source_table": "Delivery_Dim",
            "source_column": "Delivery Number"
          },
          {
            "id": "Delivery_Status",
            "label": "Delivery Status",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "Orders_at_Risk"
            ],
            "source_table": "Delivery_Dim",
            "source_column": "Delivery_Status"
          },
          {
            "id": "InFull_Probability_Raw",
            "label": "In-full probability (raw)",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "Predictive_OTIF_Pct"
            ],
            "source_table": "_ARIS.Case",
            "source_column": "In-full probability"
          },
          {
            "id": "On_Time_Probability_Raw",
            "label": "On-time probability (raw)",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "Predictive_OTIF_Pct"
            ],
            "source_table": "_ARIS.Case",
            "source_column": "On-time probability"
          },
          {
            "id": "Order_Quantity",
            "label": "Order Quantity",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "InFull",
              "Delay_Risk",
              "OTIF",
              "Stock_Shortage"
            ],
            "source_table": "Sales Order DIM",
            "source_column": "Order Quantity"
          },
          {
            "id": "Requested_Delivery_Date",
            "label": "Requested Delivery Date",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "On_Time",
              "Avg_Delay_Duration",
              "Delay_Risk",
              "OTIF"
            ],
            "source_table": "Sales Order DIM",
            "source_column": "Requested_Delivery_Date"
          },
          {
            "id": "Route_Disruption",
            "label": "Delivery Impacted by Route Disruptions",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "Transport_Delay"
            ],
            "source_table": "Supply_Chain_KPI_Tuned",
            "source_column": "Delivery Impacted by Route Disruptions"
          },
          {
            "id": "Sales_Order_Number",
            "label": "Sales Order Number",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "On_Time_Probability",
              "OTIF_Pct"
            ],
            "source_table": "Sales Order DIM",
            "source_column": "Sales Order Number"
          },
          {
            "id": "Shipment_Affected_Raw",
            "label": "Shipment Affected (raw)",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "Shipment_Affected"
            ],
            "source_table": "Supply_Chain_KPI_Single_",
            "source_column": "Shipment Affected"
          },
          {
            "id": "Warehouse_Issue_Raw",
            "label": "Warehouse Issue (raw)",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "Warehouse_Issue"
            ],
            "source_table": "Supply_Chain_KPI_Single_",
            "source_column": "Warehouse Issue"
          },
          {
            "id": "Warehouse_Quantity",
            "label": "Warehouse QUANTITY",
            "type": "source",
            "depends_on": [],
            "feeds_into": [
              "Stock_Shortage"
            ],
            "source_table": "Warehouse DIM",
            "source_column": "QUANTITY"
          }
        ]
      },
      {
        "level": 1,
        "label": "First-Order Derived KPIs",
        "nodes": [
          {
            "id": "Avg_Days_Delay_Duration",
            "label": "Avg Days Delay Duration",
            "type": "derived",
            "depends_on": [
              "Avg_Delay_Duration_ms"
            ],
            "feeds_into": [
              "Days_Range_Delay"
            ],
            "logic": "Avg delay duration / 86400000"
          },
          {
            "id": "Avg_Delay_Days_Dashboard",
            "label": "Avg. Delay days",
            "type": "dashboard_metric",
            "depends_on": [
              "Avg_Delay_Duration_ms"
            ],
            "feeds_into": [],
            "logic": "MED(Avg delay duration)"
          },
          {
            "id": "Avg_Delay_Duration",
            "label": "Avg Delay Duration",
            "type": "derived",
            "depends_on": [
              "Actual_Delivery_Date",
              "Requested_Delivery_Date"
            ],
            "feeds_into": [],
            "logic": "TIME_BETWEEN(Requested Delivery Date, Actual delivery Date) when Actual > Requested"
          },
          {
            "id": "Delay_Order_Value",
            "label": "Delay Order Value (EUR)",
            "type": "dashboard_metric",
            "depends_on": [
              "Cases_Table"
            ],
            "feeds_into": []
          },
          {
            "id": "Delay_Risk",
            "label": "Delay Risk",
            "type": "derived",
            "depends_on": [
              "Actual_Delivery_Date",
              "Requested_Delivery_Date",
              "Delivered_Quantity",
              "Order_Quantity"
            ],
            "feeds_into": [
              "Risk_Ratio"
            ],
            "logic": "CASE WHEN Actual > Requested AND Delivered Quantity < Order Quantity THEN 1 ELSE 0 END"
          },
          {
            "id": "InFull",
            "label": "InFull",
            "type": "derived",
            "depends_on": [
              "Delivered_Quantity",
              "Order_Quantity"
            ],
            "feeds_into": [],
            "logic": "CASE WHEN Delivered Quantity >= Order Quantity THEN 1 ELSE 0 END"
          },
          {
            "id": "Num_Materials",
            "label": "# Materials",
            "type": "dashboard_metric",
            "depends_on": [
              "Cases_Table"
            ],
            "feeds_into": []
          },
          {
            "id": "Num_Total_Operators",
            "label": "# Total Operators",
            "type": "dashboard_metric",
            "depends_on": [
              "Cases_Table"
            ],
            "feeds_into": []
          },
          {
            "id": "Num_Warehouse",
            "label": "#Warehouse",
            "type": "dashboard_metric",
            "depends_on": [
              "Cases_Table"
            ],
            "feeds_into": []
          },
          {
            "id": "OTIF",
            "label": "OTIF",
            "type": "derived",
            "depends_on": [
              "Actual_Delivery_Date",
              "Requested_Delivery_Date",
              "Delivered_Quantity",
              "Order_Quantity"
            ],
            "feeds_into": [
              "OTIF_Pct"
            ],
            "logic": "CASE WHEN Actual <= Requested AND Delivered >= Ordered THEN 1 ELSE 0 END"
          },
          {
            "id": "On_Time",
            "label": "On Time",
            "type": "derived",
            "depends_on": [
              "Actual_Delivery_Date",
              "Requested_Delivery_Date"
            ],
            "feeds_into": [
              "On_Time_Probability",
              "Delivery_On_Time_Pct"
            ],
            "logic": "CASE WHEN Actual delivery Date <= Requested Delivery Date THEN 1 ELSE 0 END"
          },
          {
            "id": "Open_Orders",
            "label": "Open Orders",
            "type": "pre_aggregated",
            "depends_on": [
              "Cases_Table"
            ],
            "feeds_into": [
              "Num_Open_Orders"
            ],
            "note": "Pre-aggregated ARIS dashboard value; use cases table as ground truth"
          },
          {
            "id": "Orders_at_Risk",
            "label": "Orders at Risk",
            "type": "derived",
            "depends_on": [
              "Delivery_Status",
              "Delay_Reason"
            ],
            "feeds_into": [
              "Orders_At_Risk_Dashboard"
            ],
            "logic": "CASE WHEN Delivery_Status != 'Delivered' AND Delay Reason != NULL THEN 1 ELSE 0 END"
          },
          {
            "id": "Packing_Accuracy",
            "label": "Packing accuracy",
            "type": "dashboard_metric",
            "depends_on": [
              "Cases_Table"
            ],
            "feeds_into": []
          },
          {
            "id": "Predictive_OTIF_Pct",
            "label": "Predictive OTIF %",
            "type": "derived",
            "depends_on": [
              "On_Time_Probability_Raw",
              "InFull_Probability_Raw"
            ],
            "feeds_into": [
              "Pred_OTIF_Dashboard"
            ],
            "logic": "On-time probability * In-full probability"
          },
          {
            "id": "Savings_Lost",
            "label": "Savings lost (EUR)",
            "type": "dashboard_metric",
            "depends_on": [
              "Cases_Table"
            ],
            "feeds_into": []
          },
          {
            "id": "Shipment_Affected",
            "label": "Shipment Affected",
            "type": "derived",
            "depends_on": [
              "Shipment_Affected_Raw"
            ],
            "feeds_into": [
              "Num_Shipment_Affected"
            ],
            "logic": "CASE WHEN Shipment Affected = 1 THEN 1 ELSE 0 END"
          },
          {
            "id": "Stock_Shortage",
            "label": "Stock Shortage in Warehouse",
            "type": "derived",
            "depends_on": [
              "Order_Quantity",
              "Warehouse_Quantity"
            ],
            "feeds_into": [
              "Risk_Ratio"
            ],
            "logic": "CASE WHEN Warehouse QUANTITY < Order Quantity THEN 1 ELSE 0 END"
          },
          {
            "id": "Transport_Delay",
            "label": "Transport Delay",
            "type": "derived",
            "depends_on": [
              "Route_Disruption"
            ],
            "feeds_into": [
              "Risk_Ratio"
            ],
            "logic": "CASE WHEN Delivery Impacted by Route Disruptions = 'Yes' THEN 1 ELSE 0 END"
          },
          {
            "id": "Utilization_Efficiency",
            "label": "Utilization Efficiency %",
            "type": "dashboard_metric",
            "depends_on": [
              "Cases_Table"
            ],
            "feeds_into": []
          },
          {
            "id": "Value_at_Risk",
            "label": "Value at Risk (EUR)",
            "type": "dashboard_metric",
            "depends_on": [
              "Cases_Table"
            ],
            "feeds_into": []
          },
          {
            "id": "Warehouse_Issue",
            "label": "Warehouse Issue",
            "type": "derived",
            "depends_on": [
              "Warehouse_Issue_Raw"
            ],
            "feeds_into": [
              "Warehouse_Issue_Dashboard",
              "Order_Warehouse_Issue"
            ],
            "logic": "CASE WHEN Warehouse Issue != 'None' THEN 1 ELSE 0 END"
          }
        ]
      },
      {
        "level": 2,
        "label": "Second-Order KPIs & Dashboard Metrics",
        "nodes": [
          {
            "id": "Days_Range_Delay",
            "label": "Days Range Delay",
            "type": "derived",
            "depends_on": [
              "Avg_Days_Delay_Duration"
            ],
            "feeds_into": [],
            "logic": "Bucket Avg Days Delay Duration into A.1-10, B.11-20, C.21-30, D.31-40, >40"
          },
          {
            "id": "Delivery_On_Time_Pct",
            "label": "Delivery on time %",
            "type": "dashboard_metric",
            "depends_on": [
              "On_Time",
              "Delivery_Number"
            ],
            "feeds_into": [],
            "note": "Also sourced from ARIS cases table as pre-aggregated KPI"
          },
          {
            "id": "Num_Open_Orders",
            "label": "# Open Orders",
            "type": "dashboard_metric",
            "depends_on": [
              "Open_Orders"
            ],
            "feeds_into": []
          },
          {
            "id": "Num_Shipment_Affected",
            "label": "# Shipment Affected",
            "type": "dashboard_metric",
            "depends_on": [
              "Shipment_Affected",
              "Cases_Table"
            ],
            "feeds_into": []
          },
          {
            "id": "OTIF_Pct",
            "label": "OTIF %",
            "type": "dashboard_metric",
            "depends_on": [
              "OTIF",
              "Sales_Order_Number"
            ],
            "feeds_into": [],
            "logic": "SUM(OTIF) / COUNT(Sales Order Number)"
          },
          {
            "id": "On_Time_Probability",
            "label": "On Time Probability",
            "type": "derived",
            "depends_on": [
              "On_Time",
              "Sales_Order_Number"
            ],
            "feeds_into": [],
            "logic": "SUM(On-time) / COUNT(Sales Order Number)"
          },
          {
            "id": "Order_Warehouse_Issue",
            "label": "Order with Warehouse Issue",
            "type": "dashboard_metric",
            "depends_on": [
              "Warehouse_Issue"
            ],
            "feeds_into": []
          },
          {
            "id": "Orders_At_Risk_Dashboard",
            "label": "Orders At Risk",
            "type": "dashboard_metric",
            "depends_on": [
              "Orders_at_Risk",
              "Cases_Table"
            ],
            "feeds_into": []
          },
          {
            "id": "Pred_OTIF_Dashboard",
            "label": "Predictive OTIF %",
            "type": "dashboard_metric",
            "depends_on": [
              "Predictive_OTIF_Pct"
            ],
            "feeds_into": [],
            "logic": "AVG(Predictive OTIF %)"
          },
          {
            "id": "Risk_Ratio",
            "label": "Risk Ratio",
            "type": "derived",
            "depends_on": [
              "Delay_Risk",
              "Stock_Shortage",
              "Transport_Delay"
            ],
            "feeds_into": [
              "Check_Predictive_OTIF"
            ],
            "logic": "(Delay Risk + Stock Shortage in Warehouse + Transport Delay) / 3"
          },
          {
            "id": "Warehouse_Issue_Dashboard",
            "label": "Warehouse Issue",
            "type": "dashboard_metric",
            "depends_on": [
              "Warehouse_Issue"
            ],
            "feeds_into": []
          }
        ]
      },
      {
        "level": 3,
        "label": "Third-Order KPIs",
        "nodes": [
          {
            "id": "Check_Predictive_OTIF",
            "label": "Check Predictive OTIF",
            "type": "derived",
            "depends_on": [
              "Risk_Ratio"
            ],
            "feeds_into": [],
            "logic": "CASE WHEN Risk ratio > 0.4 THEN 1 ELSE 0 END"
          }
        ]
      }
    ],
